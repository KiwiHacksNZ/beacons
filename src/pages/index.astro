---
const filloutBaseUrl = "https://kiwihacks.fillout.com/nova";
const novaLogoUrl = "/nova-logo.png";
---

<!doctype html>
<html lang="en-NZ">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>KiwiHacks Signup</title>
    <link rel="icon" type="image/png" href={novaLogoUrl} />
  </head>
  <body>
    <header>
      <nav>
        <img src={novaLogoUrl} alt="Nova by KiwiHacks" />
      </nav>
      <div class="pink-strip"></div>
    </header>

    <main>
      <img class="hero-logo" src={novaLogoUrl} alt="Nova by KiwiHacks" />
      <p class="eyebrow">Beacon signup</p>
      <h1>Taking you to Nova</h1>
      <p id="message">Preparing your KiwiHacks signup link…</p>
      <a id="manual-link" class="button" href={filloutBaseUrl}>Continue to form</a>
    </main>

    <footer>
      Built with ❤️ by teens, for teens.
    </footer>

    <script>
      const filloutUrl = new URL("https://kiwihacks.fillout.com/nova");
      const referralCodeField = "Referral Code";

      const pathCode = window.location.pathname
        .split("/")
        .filter(Boolean)[0];
      const queryCode = new URLSearchParams(window.location.search).get("ref");
      const refCode = decodeURIComponent(pathCode || queryCode || "").trim();

      if (refCode) {
        filloutUrl.searchParams.set("ref", refCode);
        filloutUrl.searchParams.set(referralCodeField, refCode);

        document.getElementById("message").innerHTML =
          'Your referral code is <span class="code"></span>.';
        document.querySelector(".code").textContent = refCode;
      } else {
        document.getElementById("message").textContent =
          "No referral code was found, but you can still sign up.";
      }

      const manualLink = document.getElementById("manual-link");
      manualLink.href = filloutUrl.toString();

      window.setTimeout(() => {
        window.location.replace(filloutUrl.toString());
      }, 650);
    </script>
  </body>
</html>

<style>
  :global(:root) {
    color-scheme: dark;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
    background: #161a3d;
    color: #ffffff;
  }

  :global(*) {
    box-sizing: border-box;
  }

  :global(body) {
    min-height: 100vh;
    margin: 0;
    display: flex;
    flex-direction: column;
    background:
      radial-gradient(circle at 22% 18%, rgba(255, 94, 160, 0.22), transparent 30%),
      radial-gradient(circle at 78% 70%, rgba(79, 70, 229, 0.3), transparent 28%),
      linear-gradient(180deg, #161a3d 0%, #0c1030 100%);
  }

  header {
    position: sticky;
    top: 0;
    z-index: 10;
    width: 100%;
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 76px;
    padding: 10px 24px;
    background: #161a3d;
  }

  nav img {
    width: auto;
    height: 56px;
    user-select: none;
  }

  .pink-strip {
    height: 3px;
    width: 100%;
    background: linear-gradient(90deg, #ff5ea0, #ff7ab3, #ff5ea0);
  }

  main {
    position: relative;
    display: flex;
    flex: 1;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: min(100%, 560px);
    margin: 0 auto;
    padding: 40px;
    text-align: center;
  }

  main::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    z-index: 0;
    width: min(calc(100vw - 48px), 760px);
    height: 260px;
    border-radius: 2rem;
    background: rgba(207, 109, 160, 0.3);
    filter: blur(32px);
    transform: translate(-50%, -45%);
  }

  .hero-logo,
  .eyebrow,
  h1,
  p,
  .button {
    position: relative;
    z-index: 1;
  }

  .hero-logo {
    width: min(72vw, 260px);
    height: auto;
    margin-bottom: 12px;
    user-select: none;
  }

  main::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    z-index: 0;
    width: min(calc(100% - 32px), 560px);
    height: 350px;
    border-radius: 2rem;
    background: rgba(12, 16, 48, 0.62);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.3);
    transform: translate(-50%, -45%);
  }

  .eyebrow {
    margin: 0 0 10px;
    color: #ff7ab3;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.35rem, 9vw, 4.6rem);
    font-weight: 700;
    line-height: 1;
  }

  p {
    margin: 18px auto 0;
    max-width: 34rem;
    color: rgba(255, 255, 255, 0.82);
    font-size: 1.08rem;
    line-height: 1.6;
  }

  a {
    color: inherit;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 28px;
    min-height: 48px;
    padding: 0 28px;
    border-radius: 1rem;
    background: #4f46e5;
    color: #ffffff;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 16px 36px rgba(0, 0, 0, 0.28);
    transition:
      background 160ms ease,
      transform 160ms ease;
  }

  .button:hover {
    background: #5b52ee;
    transform: translateY(-1px);
  }

  .code {
    font-weight: 700;
    color: #ffffff;
  }

  footer {
    padding: 24px;
    color: rgba(255, 255, 255, 0.78);
    text-align: center;
  }

  @media (max-width: 640px) {
    nav {
      min-height: 68px;
    }

    nav img {
      height: 48px;
    }

    main {
      padding: 32px 24px;
    }

    .hero-logo {
      width: min(74vw, 220px);
    }
  }
</style>
